
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Chat {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("New chat")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id          String       @id @default(cuid())
  chatId      String
  chat        Chat         @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role        String   // "user" | "assistant"
  content     String
  createdAt   DateTime     @default(now())
  attachments Attachment[]
}

model Attachment {
  id         String   @id @default(cuid())
  userId     String
  messageId  String?
  message    Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mimeType   String
  filename   String
  sizeBytes  Int
  storedPath String
  createdAt  DateTime @default(now())
}

model Memory {
  id        String   @id @default(cuid())
  userId    String
  content   String
  createdAt DateTime @default(now())
  // "embedding" vector(1536) column is added via raw SQL in the migration in Task 1.2
}

// A person we've called, identified by email (scoped to the operator's userId).
model Person {
  id         String   @id @default(cuid())
  userId     String
  email      String
  name       String? // display name, captured on first interaction
  background String   @default("") // operator-provided "what we know" seed
  summary    String   @default("") // rolling "engagement summary"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  calls      Call[]

  @@unique([userId, email])
}

// One logged outbound call. `id` is Retell's call_id (idempotent on webhook retries).
model Call {
  id                  String   @id
  userId              String
  personId            String?
  person              Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  chatId              String?
  fromNumber          String?
  toNumber            String?
  agentId             String?
  status              String?
  disconnectionReason String?
  durationSec         Int      @default(0)
  transcript          String   @default("")
  summary             String   @default("")
  personEmail         String?
  createdAt           DateTime @default(now())

  @@index([userId, createdAt])
  @@index([personId])
}
