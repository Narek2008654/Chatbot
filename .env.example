# ─── Server ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string (matches docker-compose defaults)
DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot

# Clerk API keys — from the Clerk dashboard (https://dashboard.clerk.com → API keys)
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key

# Allowed origin for CORS (your Vite dev server)
CLIENT_URL=http://localhost:5173

# OpenAI API key — obtain at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI model to use for chat completions
CHAT_MODEL=gpt-4o-mini

# OpenAI model to use for text embeddings (text-embedding-3-small => 1536 dims)
EMBEDDING_MODEL=text-embedding-3-small

# RetellAI API key (https://dashboard.retellai.com) — lets the bot create voice agents
RETELL_API_KEY=your-retell-api-key-here

# Default number to place outbound calls FROM (E.164). Must be a number you've
# registered in Retell. Lets the bot dial without being told the caller ID each time.
RETELL_FROM_NUMBER=+12182070114

# ─── Client ───────────────────────────────────────────────────────────────────

# Base URL of the Express API server (consumed by Vite via import.meta.env)
VITE_API_URL=http://localhost:3000

# Clerk publishable key (same value as CLERK_PUBLISHABLE_KEY above)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
